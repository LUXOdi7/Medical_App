<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".HorariosDisponiblesFragment">

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:id="@+id/swipeHorarios"
        android:layout_gravity="top">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:id="@+id/layoutBusquedaListado"
            android:orientation="vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="12dp">

            <!--Lista desplegable para buscar por especialidad -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:id="@+id/tilEspecialidad"
                android:hint="Especialidad"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu">

                <AutoCompleteTextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="none"
                    android:id="@+id/actvEspecialidad"/>


            </com.google.android.material.textfield.TextInputLayout>

            <!--Layout de fechas -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="2dp">
                <com.google.android.material.chip.Chip
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:id="@+id/chipDesde"
                    style="@style/Widget.Material3.Chip.Input.Icon"
                    app:chipIconVisible="true"
                    app:chipIcon="@drawable/ic_date_range"
                    android:textSize="12sp"
                    android:text="11/06/2026"/>

                <com.google.android.material.chip.Chip
                    android:layout_marginLeft="5dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:id="@+id/chipHasta"
                    style="@style/Widget.Material3.Chip.Input.Icon"
                    app:chipIconVisible="true"
                    app:chipIcon="@drawable/ic_date_range"
                    android:textSize="12sp"
                    android:text="25/06/2026"/>
                <com.google.android.material.chip.Chip
                    android:layout_marginLeft="5dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:id="@+id/chipFiltrar"
                    style="@style/Widget.Material3.Chip.Assist.Elevated"
                    app:chipIconVisible="true"
                    app:chipIcon="@drawable/ic_database_search"
                    app:chipBackgroundColor="@color/blue_200"
                    android:textSize="12sp"
                    android:layout_weight="1"
                    android:text="Filtrar"/>
            </LinearLayout>



        </LinearLayout>


    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>